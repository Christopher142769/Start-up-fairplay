# PORT : Render injecte automatiquement PORT — ne pas fixer en prod sauf besoin local.
PORT=4000

# Base MongoDB (obligatoire). En prod : Atlas ou base managée Render.
# Exemple Atlas : mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/fairplay?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/fairplay

JWT_SECRET=change_me_min_16_chars_random_string

# CORS : origine exacte du front déployé (schéma + domaine, sans slash final).
# Render Static Site ex. : https://fairplay-web.onrender.com
# En dev avec proxy Vite, tu peux laisser vide ou utiliser http://localhost:5173
# CLIENT_ORIGIN=http://localhost:5173

# Compte admin initial (créé par `npm run seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_strong_password
# Si l’admin existe déjà : remets le mot de passe voulu ci-dessus puis une seule fois :
# ADMIN_RESET_PASSWORD=true npm run seed
# (ou export ADMIN_RESET_PASSWORD=true avant la commande)

# SMTP (Gmail : mot de passe d’application, sans espaces ou avec — le code retire les espaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_compte@gmail.com
SMTP_PASS=votre_mot_de_passe_application
MAIL_FROM="Fair Play <votre_compte@gmail.com>"
